# =============================================================================
# AI Quant Trading Platform — 환경 변수 설정
# =============================================================================
# 사용법: cp .env.example .env  →  .env 파일 수정
#
# ✅ = 키 불필요 (지금 바로 동작)
# 📝 = 무료 가입 후 발급 (선택사항, 없어도 동작)
# ❌ = 현재 미사용 (향후 확장용)
# =============================================================================

# ─────────────────────────────────────────────
# 기본 설정
# ─────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# 데이터베이스 (Docker로 자동 설정됨)
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quant_user
POSTGRES_PASSWORD=quant_secure_2024
POSTGRES_DB=quant_db

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=quant

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────
# ✅ 키 없이 바로 사용 가능한 데이터 소스
# ─────────────────────────────────────────────

# Yahoo Finance: 별도 설정 불필요 (yfinance 라이브러리가 알아서 처리)
# 지원: AAPL, MSFT, 005930.KS, BTC-USD, ^KS11, USDKRW=X 등

# KRX (한국 주식): 별도 설정 불필요 (FinanceDataReader/pykrx)
# 지원: 005930 (삼성전자), 000660 (SK하이닉스), KS11 (코스피) 등

# Binance 공개 API: 키 없이 시장 데이터 사용 가능
# 지원: BTCUSDT, ETHUSDT, SOLUSDT 실시간 WebSocket 포함

# CoinGecko: 별도 설정 불필요 (공개 API)
# 지원: BTC, ETH, SOL 등 암호화폐 OHLCV

# ─────────────────────────────────────────────
# 📝 선택사항: 무료 가입 후 키 발급
# ─────────────────────────────────────────────

# Alpha Vantage (미국 주식 보완)
# 발급: https://www.alphavantage.co/support/#api-key
# 무료 한도: 25 req/일, 500 req/월
# 없어도 Yahoo Finance로 대체됨
ALPHA_VANTAGE_KEY=

# FRED (미국 연방준비은행 거시경제 데이터)
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
# 무료 한도: 무제한
# 제공: 금리(DFF), CPI, 실업률, GDP, 국채금리 등
FRED_API_KEY=

# ─────────────────────────────────────────────
# ❌ 현재 미사용 (실거래 연동 시 필요)
# ─────────────────────────────────────────────

# Binance 트레이딩 키 (시장데이터는 키 불필요, 주문 실행 시에만 필요)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# 한국투자증권 KIS API (실거래 연동용, 지금은 불필요)
KIS_APP_KEY=
KIS_APP_SECRET=

# ─────────────────────────────────────────────
# API 서버 설정
# ─────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# JWT 보안 (프로덕션에서 반드시 긴 랜덤 문자열로 변경)
JWT_SECRET=dev_jwt_secret_change_in_production_use_long_random_string

# ─────────────────────────────────────────────
# ML 설정
# ─────────────────────────────────────────────
ML_USE_GPU=false
ML_GPU_DEVICE=0
ML_MODEL_PATH=data/models
ML_LOOKBACK=252
ML_FORECAST=5

# ─────────────────────────────────────────────
# 백테스팅 기본값
# ─────────────────────────────────────────────
BT_COMMISSION_BPS=5.0
BT_SLIPPAGE_BPS=2.0
BT_INITIAL_CAPITAL=100000000

# ─────────────────────────────────────────────
# 리스크 관리 한도
# ─────────────────────────────────────────────
RISK_MAX_POSITION=0.10
RISK_MAX_DRAWDOWN=0.15
RISK_DAILY_LOSS=0.02

# ─────────────────────────────────────────────
# 모니터링 (docker-compose --profile monitoring)
# ─────────────────────────────────────────────
GRAFANA_PASSWORD=admin123
FLOWER_USER=admin
FLOWER_PASSWORD=admin123
