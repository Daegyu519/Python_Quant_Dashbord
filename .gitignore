# =============================================================================
# .gitignore — AI Quant Trading Platform
# =============================================================================

# ── 비밀/환경 변수 (절대 커밋 금지!) ─────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.*
# .env.example 은 커밋함(플레이스홀더 템플릿)
!.env.example

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ── 가상환경 ─────────────────────────────────────────────────
venv/
env/
.venv/
ENV/

# ── 테스트/린트/타입 캐시 ────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── Jupyter / Streamlit ──────────────────────────────────────
.ipynb_checkpoints/
.streamlit/secrets.toml

# ── 데이터 & DB ──────────────────────────────────────────────
/data/                 # 루트 런타임 데이터만 제외 (app/data 소스코드는 포함)
*.duckdb
*.db
*.sqlite
*.sqlite3
*.parquet
*.csv

# ── ML 모델 가중치 ───────────────────────────────────────────
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# ── 생성된 차트/리포트 산출물 ────────────────────────────────
/charts/
/reports/
/output/

# ── 로그 ─────────────────────────────────────────────────────
/logs/
*.log

# ── 프론트엔드 (Next.js) ─────────────────────────────────────
node_modules/
.next/
out/
frontend/node_modules/
frontend/.next/

# ── IDE / 에디터 ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ── Numba 캐시 ───────────────────────────────────────────────
__numba_cache__/

# ── 개인 자료 (포트폴리오 공개 제외) ────────────────────────
면접_설명서.docx
면접_설명서.md
*.docx

# 로컬 영속 저장(모의 포트폴리오 등) — 커밋 안 함
.data/

# ── 🔒 비공개: 자동매매 봇 & 독자 노하우 (절대 커밋 금지) ──────
# (주의: .gitignore 는 인라인 주석 미지원 — 패턴은 반드시 단독 줄에)
# 자동매매 봇(신호→사이징→모의체결) · Celery 앱·봇 스케줄러
app/trading/
app/tasks/
# 봇용 분석 결합 코어 · 봇 테스트
app/analytics/analysis.py
app/tests/unit/test_trading.py
# 자동매매·퀀트 설계 서술 + 봇 성과 대시보드 (로컬 전용)
claude.md
bot_dashboard.py
# 뉴스 LLM(Gemini) 파이프라인 — 실수 커밋 방지로 무시. 공개하려면 이 줄 삭제.
app/news/
